[sub_resource type="Shader" id="Shader_bq5lc"]
code = "shader_type canvas_item;

uniform float move_strength = 3.0;   // pixels
uniform float rotate_strength = 0.02; // radians
uniform float speed = 1.5;

void vertex() {
    float t = TIME * speed;

    // Small position wobble
    vec2 offset = vec2(
        sin(t * 1.3),
        cos(t * 1.1)
    ) * move_strength;

    // Rotation
    float angle = sin(t) * rotate_strength;
    mat2 rot = mat2(
        vec2(cos(angle), -sin(angle)),
        vec2(sin(angle),  cos(angle))
    );

    VERTEX = rot * VERTEX + offset;
}
"

